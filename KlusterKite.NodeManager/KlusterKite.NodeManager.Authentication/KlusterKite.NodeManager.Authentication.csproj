<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="..\..\common.props" />
  <PropertyGroup>
    <TargetFrameworks>net9.0</TargetFrameworks>
    <PackageId>KlusterKite.NodeManager.Authentication</PackageId>
    <Version>0.0.0.0-local</Version>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Description>KlusterKite NodeManager authentication</Description>
    <PackageTags>$(KlusterKitePackageTags);NodeManager;Authentication</PackageTags>    
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(TargetFramework)|$(Platform)'=='Debug|net6.0|x64'" />
  <ItemGroup>
    <None Remove="Resources\akka.hocon" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Resources\akka.hocon" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\KlusterKite.Core\KlusterKite.Core\KlusterKite.Core.csproj" />
    <ProjectReference Include="..\..\KlusterKite.Security\KlusterKite.Security.Attributes\KlusterKite.Security.Attributes.csproj" />
    <ProjectReference Include="..\KlusterKite.NodeManager.Client\KlusterKite.NodeManager.Client.csproj" />
  </ItemGroup>
  
  <PropertyGroup Condition=" '$(TargetFramework)' == 'net9.0' ">
    <DefineConstants>$(DefineConstants);APPDOMAIN</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DefineConstants>$(DefineConstants);RELEASE</DefineConstants>
  </PropertyGroup>
</Project>