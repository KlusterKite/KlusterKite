<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="..\..\common.props" />
  <PropertyGroup>
    <TargetFrameworks>net9.0</TargetFrameworks>
    <PackageId>KlusterKite.LargeObjects.Client</PackageId>
    <Version>0.0.0.0-local</Version>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Description>KlusterKite large objects client</Description>
    <PackageTags>$(KlusterKitePackageTags);LargeObjects</PackageTags>    
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(TargetFramework)|$(Platform)'=='Debug|net6.0|x64'" />
  <ItemGroup>
    <None Remove="Resources\akka.hocon" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Resources\akka.hocon" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Akka" Version="1.5.45" />
    <PackageReference Include="Autofac" Version="8.3.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\KlusterKite.Core\KlusterKite.Core\KlusterKite.Core.csproj" />
  </ItemGroup>
  
  <PropertyGroup Condition=" '$(TargetFramework)' == 'net9.0' ">
    <DefineConstants>$(DefineConstants);APPDOMAIN</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DefineConstants>$(DefineConstants);RELEASE</DefineConstants>
  </PropertyGroup>
</Project>